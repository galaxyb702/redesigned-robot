# This program will encode a message using the ASCII values

# for the characters and display it to the screen. Then decode

# the message for the user to read.

 

def main():

 

    message = "Try not to become a man of success but rather try to become a man of value. -Albert Einstein"

    encodedMsg = []

    decodedMsg = ""

 

    # Encode the message to ASCII.

    for m in message:

        encodedMsg.append( ord(m) )

 

    print("The encoded message: ")

    print(encodedMsg)

    print("")

    

    for e in encodedMsg:

        decodedMsg = decodedMsg + chr( e )

 

    print("The decoded message: ")

    print(decodedMsg)

 

main() 
